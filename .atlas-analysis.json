  "keyFeatures": [
    "Type-safe asynchronous and concurrent programming",
    "Lightweight fibers with high scalability",
    "Composable error handling with typed errors",
    "Resource-safe with automatic cleanup",
    "Built-in dependency injection with ZLayer",
    "Powerful streaming with ZStream",
    "Software Transactional Memory (STM)",
    "Comprehensive testing framework",
    "Property-based testing with Gen",
    "Retry and repeat with Schedule"
  ],
  "publicApiSurface": [
    "ZIO[R, E, A] - Core effect type",
    "ZIO.succeed/fail/attempt - Effect constructors",
    "ZStream[R, E, A] - Streaming data type",
    "ZSink[R, E, In, L, Z] - Stream consumer",
    "ZPipeline[R, E, In, Out] - Stream transformer",
    "ZSTM[R, E, A] - STM effect type",
    "ZLayer[RIn, E, ROut] - Dependency injection",
    "Fiber[E, A] - Lightweight thread",
    "Ref[A] - Atomic reference",
    "Queue[A] - Concurrent queue",
    "Hub[A] - Publish-subscribe hub",
    "Promise[E, A] - Async promise",
    "Semaphore - Concurrency control",
    "Schedule[R, In, Out] - Retry/repeat policies",
    "Scope - Resource lifecycle management",
    "ZIO.runtime - Runtime access",
    "ZIO.service - Service access",
    "Spec[R, E] - Test specification",
    "Assertion[A] - Test assertions",
    "Gen[R, A] - Property-based test generator",
    "TestAspect - Test modifiers",
    "TRef[A] - Transactional reference",
    "TArray[A] - Transactional array",
    "TMap[K, V] - Transactional map",
    "TQueue[A] - Transactional queue",
    "Clock - Time service",
    "Console - Console I/O service",
    "Random - Random number service",
    "System - System properties service"
  ]
